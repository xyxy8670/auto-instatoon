{
  "name": "instatoon-studio-codex",
  "version": "0.1.0",
  "description": "A local Codex-powered studio for turning Korean briefs into 4:5 Instagram carousel comic cards.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "codex",
    "openai",
    "instatoon",
    "instagram-carousel",
    "webtoon",
    "creator-tools",
    "local-first"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"node --watch server/index.mjs\" \"vite\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "lucide-react": "^0.560.0",
    "openai-oauth": "^1.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "qs": "6.15.2"
  }
}
