# Auto InstaToon local config
#
# Copy when needed:
#   cp .env.example .env.local
#
# Login once on this Mac:
#   npx @openai/codex login

LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8787
LOCAL_API_JSON_LIMIT=80mb

CODEX_OAUTH_PROXY_PORT=10531
CODEX_TEXT_MODEL=gpt-5.5
CODEX_IMAGE_MODEL=gpt-5.5
CODEX_REQUEST_TIMEOUT_MS=600000

# Optional dev-server host. Keep local by default.
# VITE_DEV_HOST=127.0.0.1
