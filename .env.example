# InstaToon Studio for Codex local configuration example.
#
# Copy this file to `.env.local`:
#
#   cp .env.example .env.local
#
# Main generation uses your local Codex/OpenAI OAuth login, not checked-in API keys.
# First login once on this machine:
#
#   npx @openai/codex login
#
# Do not put private tokens, account cookies, generated user content, or real
# project archive files in git.

# ---------------------------------------------------------------------------
# Codex OAuth proxy
# ---------------------------------------------------------------------------
# Local proxy port used by the backend to reach the Codex OAuth session.
# Optional. Default: 10531
CODEX_OAUTH_PROXY_PORT=10531

# Text/planning model requested through Codex OAuth.
# Optional. Default: gpt-5.5
CODEX_TEXT_MODEL=gpt-5.5

# Image generation model requested through Codex OAuth.
# Optional. Keep this aligned with models available in your Codex account.
# This example uses gpt-5.4-mini; if unset, runtime code may fall back to its
# internal default.
CODEX_IMAGE_MODEL=gpt-5.4-mini

# Image moderation setting forwarded to the image request.
# Optional. Default: low
CODEX_IMAGE_MODERATION=low

# ---------------------------------------------------------------------------
# Local API server
# ---------------------------------------------------------------------------
# Express backend port.
# Optional. Default: 8787
LOCAL_API_PORT=8787

# Express backend host.
# Optional. Default: 127.0.0.1.
# Keep this local-only unless you intentionally expose the app on a trusted LAN.
LOCAL_API_HOST=127.0.0.1

# Maximum JSON request size accepted by the local API.
# Uploading PDFs sends base64 JSON, so the request can be larger than the file.
# Optional. Default: 180mb
LOCAL_API_JSON_LIMIT=180mb

# Legacy Gemini file handling, only used by the optional `/api/gemini/generate-content`
# compatibility endpoint. The main app uses Codex OAuth for text/planning.
GEMINI_FILE_API_ALWAYS_UPLOAD_PDFS=true
GEMINI_FILE_API_INLINE_MAX_BYTES=18874368
GEMINI_PDF_MAX_BYTES=52428800
GEMINI_PDF_SPLIT_TARGET_BYTES=47185920
GEMINI_PDF_SPLIT_MAX_PARTS=12
GEMINI_PDF_TEXT_FALLBACK_MAX_CHARS=120000

# Vite dev server host.
# Optional. Default: 127.0.0.1.
# Use command-line overrides for one-off LAN testing instead of committing changes.
# VITE_DEV_HOST=0.0.0.0

# Local project archive path.
# Optional. If empty, the app writes to ./local-project-archive/projects.json.
# Use an absolute path if you want archives outside this repository.
# LOCAL_PROJECT_ARCHIVE_PATH=/absolute/path/projects.json

# ---------------------------------------------------------------------------
# Frontend-visible planner/research settings
# ---------------------------------------------------------------------------
# These VITE_* values are visible to the browser. Do not put secrets here.

# Planner/research models used by the UI and client-side request builders.
# Optional. Defaults are safe for local development.
VITE_CODEX_PLANNER_MODEL=gpt-5.5
VITE_CODEX_RESEARCH_MODEL=gpt-5.5

# Research output budget.
# Optional. Default: 8000
VITE_CODEX_RESEARCH_MAX_OUTPUT_TOKENS=8000

# Codex planning output length for narrative/page planning.
# Optional. Default: 30000
VITE_CODEX_MAX_OUTPUT_TOKENS=30000
VITE_CODEX_PLANNER_MAX_OUTPUT_TOKENS=30000

# Max pages per single planning request.
# Optional. Lower this if long plans fail on your machine/account.
# Default: 10
VITE_CODEX_MAX_PAGES_PER_REQUEST=10

# Page count caps.
# Optional. Keep frontend and backend values aligned.
# - VITE_MAX_PAGE_COUNT affects UI validation.
# - LOCAL_API_MAX_PAGE_COUNT affects backend research recommendation clamping.
# Default: 12
VITE_MAX_PAGE_COUNT=12
LOCAL_API_MAX_PAGE_COUNT=12
